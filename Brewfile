# Farm Ledger Homebrew dependencies. Install with: brew bundle
# NOTE: The Claude Code CLI is installed separately via npm — see README.md.

# Python 3.10+ for the Flask app
brew "python@3.12"

# Node.js — required for the Claude Code CLI (installed via `npm install -g @anthropic-ai/claude-code`)
brew "node"

# Headless terminal-over-websocket that hosts the Claude CLI panes in the UI
brew "ttyd"
